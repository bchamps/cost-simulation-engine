# =============================================================================
# DATA ARTIFACTS (Do not commit large synthetic or raw data files)
# =============================================================================
*.csv
*.dat
*.parquet
data/*.csv
data/sample_*.csv

# =============================================================================
# PYTHON & ENVIRONMENT
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.venv/
venv/
ENV/

# =============================================================================
# GCP SECURITY & CREDENTIALS (CRITICAL: Never commit cloud keys)
# =============================================================================
*.json
!schema_*.json
!*examples*.json
*-private-key.json
credentials.json
service_account*.json
.env

# =============================================================================
# LOCAL SANDBOX & PREVIEW ARTIFACTS (Do not commit local UI test harnesses)
# =============================================================================
local-preview.html
preview.html
*sandbox*.html

# =============================================================================
# OS & IDE NOISE
# =============================================================================
.DS_Store
.idea/
.vscode/
*.swp
*.swo